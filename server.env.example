# Copie este arquivo para .env.server e substitua todos os valores CHANGE_ME.
POSTGRES_USER=impar
POSTGRES_PASSWORD=CHANGE_ME_DATABASE_PASSWORD
POSTGRES_DB=imparoutfit

JWT_SECRET=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d

# Durante o primeiro teste nativo, * permite chamadas do aplicativo.
# Antes de publicar uma versão web, informe os domínios separados por vírgula.
CORS_ORIGIN=*

# Necessário para uploads reais de imagens.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Token de um Cloudflare Tunnel gerenciado remotamente.
# Nunca compartilhe ou versione o valor real.
CLOUDFLARE_TUNNEL_TOKEN=CHANGE_ME_CLOUDFLARE_TUNNEL_TOKEN
